# ============================================
# Environment Variables - Example
# ============================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب سيرفرك
# على السيرفر: أنشئ ملف api/.env يدوياً (لا يُنشر عبر Git)

# إعدادات قاعدة البيانات (مطلوبة على السيرفر)
# على الاستضافة: استخدم بيانات MySQL من لوحة التحكم (DB_HOST قد يكون مثل mysql.hostinger.com)
# تأكد من إنشاء قاعدة البيانات أولاً (استورد database-schema.sql أو nayl.sql)
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_db_user
# DB_PASS مطلوب على معظم الاستضافات؛ محلياً قد يكون root بدون كلمة مرور
DB_PASS=your_db_password
DB_PORT=3306
DB_CHARSET=utf8mb4

# إعدادات التطبيق
APP_ENV=production
APP_DEBUG=false
APP_URL=https://almoustafa.site

# إعدادات Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_LOCKOUT_SECONDS=1800
# تعطيل حد معدل تسجيل الدخول على السيرفر إذا كان يعيد 429 (ضع false ثم أعد النشر)
# RATE_LIMIT_LOGIN_ENABLED=false

# إعدادات Bunny CDN (إن وُجدت)
# BUNNY_LIBRARY_ID=
# BUNNY_API_KEY=
# BUNNY_ACCOUNT_API_KEY=
# BUNNY_CDN_URL=
