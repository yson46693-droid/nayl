# ============================================
# Environment Variables - Example
# ============================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب سيرفرك
# على السيرفر: أنشئ ملف api/.env يدوياً (لا يُنشر عبر Git)

# إعدادات قاعدة البيانات (مطلوبة على السيرفر)
# مهم: كل متغير في سطر منفصل. إذا كانت كلمة المرور تحتوي على = أو رموز خاصة ضعها بين علامتي اقتباس: DB_PASS="your&pass"
# على الاستضافة: استخدم بيانات MySQL من لوحة التحكم (DB_HOST قد يكون مثل srv123.hstgr.io)
# حد 500 اتصال/ساعة لا يمكن رفعه من phpMyAdmin (يحتاج CREATE USER). الحل: DB_PERSISTENT=true فقط + تقليل الاستدعاءات (مطبّق في التطبيق)، أو طلب رفع الحد من دعم الاستضافة
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password
DB_PORT=3306
DB_CHARSET=utf8mb4
# تقليل عدد الاتصالات المحسوبة (مهم عند حد 500/ساعة). لرفع الحد نهائياً: شغّل mysql-raise-connection-limit.sql أو اطلب من الاستضافة رفع max_connections_per_hour
DB_PERSISTENT=true

# إعدادات التطبيق
APP_ENV=production
APP_DEBUG=false
APP_URL=https://almoustafa.site
# اسم التطبيق (يظهر في البريد والويب أوثن)
APP_NAME=AmrNayl Academy
# نطاقات إضافية مسموح لها في CORS (اختياري، مفصولة بفاصلة بدون مسافات)
# ALLOWED_ORIGINS_EXTRA=https://www.example.com,https://app.example.com

# البريد الإلكتروني (للإشعارات واستعادة كلمة المرور)
MAIL_FROM_EMAIL=noreply@amrnayl.com
MAIL_FROM_NAME=AmrNayl Academy

# إعدادات Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_LOCKOUT_SECONDS=1800
# تعطيل حد معدل تسجيل الدخول على السيرفر إذا كان يعيد 429 (ضع false ثم أعد النشر)
# RATE_LIMIT_LOGIN_ENABLED=false
# حد تسجيل الحسابات الجديدة (محاولات في النافذة الزمنية)
SIGNUP_RATE_LIMIT_MAX=5
SIGNUP_RATE_LIMIT_WINDOW=3600

# إعدادات Bunny CDN (إن وُجدت)
# معرف مكتبة الفيديوهات (مطلوب لإضافة فيديوهات للكورسات)
BUNNY_LIBRARY_ID=602302
# BUNNY_API_KEY=
# BUNNY_ACCOUNT_API_KEY=
# مفتاح Token Authentication من Bunny Stream → Library → Security (لـ signed embed URLs)
# BUNNY_TOKEN_KEY=
# BUNNY_CDN_URL=
